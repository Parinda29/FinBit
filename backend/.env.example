# Django development settings
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-in-production

# Comma-separated hosts. ngrok host is auto-appended from NGROK_URL.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ngrok public URL (set by script or manually)
NGROK_URL=

# CORS / CSRF for mobile + web clients
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:19000,http://localhost:19001,http://localhost:8081,http://127.0.0.1:19000,http://127.0.0.1:8081,http://10.0.2.2:19000,http://10.0.2.2:8081
CSRF_TRUSTED_ORIGINS=
